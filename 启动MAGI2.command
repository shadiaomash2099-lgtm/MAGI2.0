#!/bin/bash
# ============================================================
# MAGI2.0 — macOS 双击启动
# 将此文件放在项目根目录，双击即可运行
# 如果第一次运行提示"无法打开"，请执行:
#   chmod +x 启动MAGI2.command
# 或在"系统设置 → 隐私与安全性"中允许运行
# ============================================================

# 切换到项目目录
cd "$(dirname "$0")"

# 给 start.sh 执行权限
chmod +x start.sh

# 在终端中执行启动脚本
./start.sh

# 等待用户按 Enter 后关闭
echo ""
echo "按 Enter 键关闭此窗口..."
read
